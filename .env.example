# Copy to .env for local development. Do not commit real secrets.
APP_ENV=local
LOG_LEVEL=INFO

# API
API_HOST=0.0.0.0
API_PORT=8080

# Model provider placeholders
MODEL_PROVIDER=openai-compatible
MODEL_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
MODEL_NAME=doubao-seed-2-0-code-preview-260215
MODEL_API_KEY=replace-with-local-secret
MODEL_TIMEOUT_SECONDS=60

# Infrastructure
REDIS_URL=redis://localhost:6379/0
POSTGRES_DSN=postgresql://agent_workflow:agent_workflow@localhost:5432/agent_workflow
QDRANT_URL=http://localhost:6333
MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET=agent-workflow-artifacts
MINIO_ACCESS_KEY=replace-with-local-secret
MINIO_SECRET_KEY=replace-with-local-secret
